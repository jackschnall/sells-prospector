# Anthropic API key — required unless MOCK_MODE=1
ANTHROPIC_API_KEY=sk-ant-...

# Set to 1 to use canned mock research instead of real API calls
# The UI will display a prominent banner when mock mode is on
MOCK_MODE=0

# Port for local dev server
PORT=3000

