# Anthropic API key — required unless MOCK_MODE=1
ANTHROPIC_API_KEY=sk-ant-...

# Set to 1 to use canned mock research instead of real API calls
# The UI will display a prominent banner when mock mode is on
MOCK_MODE=0

# Port for local dev server
PORT=3000

# --- Twilio (leave blank for mock call mode) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_PHONE_NUMBER=+1...

# Public base URL for Twilio webhooks (required for live calls)
PUBLIC_URL=https://sells-prospector-production-f51b.up.railway.app

# Force mock calls even if Twilio keys present (dev/testing)
MOCK_CALLS=0

# --- OpenAI Whisper (leave blank to skip transcription) ---
OPENAI_API_KEY=sk-...

# --- Salesforce (stubbed in v1 — manual paste list is used instead) ---
# SF_CLIENT_ID=
# SF_CLIENT_SECRET=
# SF_REDIRECT_URI=http://localhost:3000/auth/callback
# SF_INSTANCE_URL=https://yourorg.salesforce.com
